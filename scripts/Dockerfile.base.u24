#    echo "build_type=Release" >> ${HOME}/.conan2/profiles/Linux-x86_64-clang-18 &&\
#    echo "compiler=clang" >> ${HOME}/.conan2/profiles/Linux-x86_64-clang-18 &&\
#    echo "compiler.cppstd=23" >> ${HOME}/.conan2/profiles/Linux-x86_64-clang-18 &&\
#    echo "compiler.libcxx=libstdc++11" >> ${HOME}/.conan2/profiles/Linux-x86_64-clang-18 &&\
#    echo "compiler.version=18" >> ${HOME}/.conan2/profiles/Linux-x86_64-clang-18 &&\
#    echo "os=Linux" >> ${HOME}/.conan2/profiles/Linux-x86_64-clang-18 &&\
#    echo "[conf]" >> ${HOME}/.conan2/profiles/Linux-x86_64-clang-18 &&\
#    echo "tools.cmake.cmaketoolchain:generator=Ninja" >> ${HOME}/.conan2/profiles/Linux-x86_64-clang-18
 
    

# We'll be using compression - zlib
WORKDIR /home/ubuntu
RUN mkdir -p /usr/local/include &&\
    mkdir -p /usr/local/lib &&\
    cd /home/ubuntu &&\
    wget -q https://zlib.net/zlib-1.3.2.tar.gz &&\
    tar -xf zlib-1.3.2.tar.gz &&\
    rm zlib-1.3.2.tar.gz &&\
    cd zlib-1.3.2  &&\
    ./configure --prefix=/usr/local &&\
    make &&\
    make install &&\
    cd /home/ubuntu &&\
    rm -r zlib-1.3.2

# I don't like how ubuntu installs boost - I get everything but I really
# don't need everything
RUN cd /home/ubuntu &&\
    wget -q https://archives.boost.io/release/1.88.0/source/boost_1_88_0.tar.gz &&\
    tar -xf boost_1_88_0.tar.gz &&\
    rm boost_1_88_0.tar.gz &&\
    cd boost_1_88_0 &&\
    ./bootstrap.sh --with-toolset=clang &&\
    ./b2 install --prefix=/usr/local --with-headers --with-program_options &&\
    cd /home/ubuntu &&\
    rm -rf boost_1_88_0

# libmseed, libslink, libdali, slinktool, spdlog, catch2
WORKDIR /home/ubuntu
RUN cd /home/ubuntu &&\
    wget -q https://github.com/EarthScope/libmseed/archive/refs/tags/v3.2.4.tar.gz &&\
    tar -xf v3.2.4.tar.gz &&\
    rm v3.2.4.tar.gz &&\
    cd libmseed-3.2.4 &&\
    cmake -B build -DCMAKE_BUILD_TYPE=Release -DCMAKE_C_COMPILER=clang -DBUILD_STATIC_LIBS=ON -DBUILD_SHARED_LIBS=OFF -DCMAKE_INSTALL_PREFIX=/usr/local &&\
    cd build &&\
    make install &&\
    cd /home/ubuntu &&\
    rm -r libmseed-3.2.4 &&\
    wget -q https://github.com/EarthScope/libslink/archive/refs/tags/v4.2.0.tar.gz &&\
    tar -xf v4.2.0.tar.gz &&\
    rm v4.2.0.tar.gz &&\
    cd libslink-4.2.0 &&\
    make static shared &&\
    make install &&\
    mv libslink.a /usr/local/lib/ &&\
    cd /home/ubuntu &&\
    rm -rf libslink-4.2.0 &&\
    wget https://github.com/EarthScope/libdali/archive/refs/tags/v1.8.1.tar.gz &&\
    tar -xf v1.8.1.tar.gz &&\
    rm v1.8.1.tar.gz &&\
    cd libdali-1.8.1 &&\
    CC=clang make &&\
    mv libdali.a /usr/local/lib/ &&\
    mv libdali.h /usr/local/include/ &&\
    cd /home/ubuntu &&\
    rm -rf libdali-1.8.1 &&\
    wget -q https://github.com/EarthScope/slinktool/archive/refs/tags/v4.5.0.tar.gz &&\
    tar -xf v4.5.0.tar.gz &&\
    rm v4.5.0.tar.gz &&\
    cd slinktool-4.5.0 &&\
    CC=clang make &&\
    mv slinktool /usr/local/bin &&\
    cd /home/ubuntu &&\
    rm -r slinktool-4.5.0 &&\
    wget -q https://github.com/catchorg/Catch2/archive/refs/tags/v3.13.0.tar.gz &&\
    tar -xf v3.13.0.tar.gz &&\
    rm v3.13.0.tar.gz &&\
    cd Catch2-3.13.0/ &&\
    cmake -B build -DCMAKE_BUILD_TYPE=Release -DCMAKE_CXX_COMPILER=clang++ &&\
    cmake --build build &&\
    cmake --install build &&\
    cd /home/ubuntu &&\
    rm -rf Catch2-3.13.0/ &&\
    wget -q https://github.com/gabime/spdlog/archive/refs/tags/v1.17.0.tar.gz &&\
    tar -xf v1.17.0.tar.gz &&\
    rm v1.17.0.tar.gz &&\
    cd spdlog-1.17.0 &&\
    cmake -B build_static -DCMAKE_BUILD_TYPE=Release -DSPDLOG_BUILD_SHARED=OFF -DCMAKE_INSTALL_PREFIX=/usr/local/ &&\
    cd build_static &&\
    make &&\
    make install &&\
    cd /home/ubuntu &&\
    rm -rf spdlog-1.17.0 &&\
    wget https://github.com/open-telemetry/opentelemetry-cpp/archive/refs/tags/v1.25.0.tar.gz &&\ 
    tar -xf v1.25.0.tar.gz &&\
    rm v1.25.0.tar.gz &&\
    cd opentelemetry-cpp-1.25.0 &&\
    mkdir build &&\
    cmake -B build -DBUILD_TESTING=OFF -DCMAKE_BUILD_TYPE=Release -DWITH_PROMETHEUS=OFF -DCMAKE_CXX_COMPILER=clang++ -DWITH_EXAMPLES=OFF -DWITH_ABI_VERSION_1=OFF -DWITH_ABI_VERSION_2=ON -DWITH_OTLP_HTTP=ON -DWITH_BENCHMARK=OFF &&\
    cmake --build build &&\
    cmake --install build &&\
    cd /home/ubuntu &&\
    rm -r opentelemetry-cpp-1.25.0 &&\
    wget https://github.com/EarthScope/ringserver/archive/refs/tags/v4.3.1.tar.gz &&\
    tar -xf v4.3.1.tar.gz &&\
    rm v4.3.1.tar.gz &&\
    cd ringserver-4.3.1 &&\
    CC=clang make &&\
    mv ringserver /usr/local/bin &&\
    cd /home/ubuntu &&\
    rm -rf ringserver-4.3.1

